// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

// ─────────────────────────────────────────────
// BetterAuth
// ─────────────────────────────────────────────

model User {
  id            String   @id
  name          String
  email         String
  emailVerified Boolean
  image         String?
  createdAt     DateTime
  updatedAt     DateTime

  sessions      Session[]
  accounts      Account[]
  memberships   WorkspaceMember[]
  invitesSent   Invitation[]      @relation("InvitedBy")
  meetings      Meeting[]
  assignedTasks Task[]

  @@unique([email])
  @@index([id])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@index([expiresAt])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}

// ─────────────────────────────────────────────
// Tenancy
// ─────────────────────────────────────────────

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
  GUEST
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members     WorkspaceMember[]
  invitations Invitation[]
  meetings    Meeting[]
  tasks       Task[]

  @@map("workspace")
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceRole @default(MEMBER)
  joinedAt    DateTime      @default(now())
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
  @@index([workspaceId])
  @@map("workspace_member")
}

model Invitation {
  id              String        @id @default(cuid())
  workspaceId     String
  email           String
  role            WorkspaceRole @default(MEMBER)
  tokenHash       String        @unique
  invitedByUserId String
  expiresAt       DateTime
  acceptedAt      DateTime?
  revokedAt       DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invitedBy User      @relation("InvitedBy", fields: [invitedByUserId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, email])
  @@index([workspaceId])
  @@map("invitation")
}

// ─────────────────────────────────────────────
// Meetings
// ─────────────────────────────────────────────

enum MeetingSource {
  UPLOAD
  BOT
}

enum MeetingStatus {
  PENDING_UPLOAD
  SCHEDULED
  UPLOADED
  TRANSCRIBING
  TRANSCRIBED
  ANALYZING
  SUMMARIZED
  FAILED
}

enum MeetingPlatform {
  ZOOM
  GOOGLE_MEET
  MICROSOFT_TEAMS
  OTHER
}

model Meeting {
  id              String           @id @default(cuid())
  workspaceId     String
  userId          String
  title           String
  source          MeetingSource    @default(UPLOAD)
  status          MeetingStatus    @default(PENDING_UPLOAD)
  audioKey        String?          @unique
  fileName        String?
  fileType        String?
  fileSize        Int?
  durationSeconds Int?
  language        String?
  summary         Json?
  /**
   * Original join URL captured for BOT-sourced meetings.
   */
  meetingUrl      String?
  /**
   * Conferencing platform inferred from `meetingUrl` (BOT source).
   */
  platform        MeetingPlatform?
  /**
   * Recall.ai bot id; unique so the webhook handler can look up the meeting.
   */
  externalBotId   String?          @unique
  /**
   * Optional future-dated start for BOT meetings (Recall scheduled bots).
   */
  scheduledAt     DateTime?
  /**
   * Soft delete — processed list endpoints exclude rows where this is set.
   */
  deletedAt       DateTime?
  /**
   * When true, meeting link sharing / visibility flags are enabled (UI).
   */
  isShared        Boolean          @default(false)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  workspace          Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user               User                @relation(fields: [userId], references: [id], onDelete: Restrict)
  processingEvents   ProcessingEvent[]
  transcriptSegments TranscriptSegment[]
  chunks             MeetingChunk[]
  tasks              Task[]

  @@index([workspaceId, createdAt(sort: Desc)])
  @@index([workspaceId, deletedAt, createdAt(sort: Desc)])
  @@index([userId])
  @@map("meeting")
}

model Task {
  id          String    @id @default(cuid())
  workspaceId String
  meetingId   String?
  title       String
  assigneeId  String?
  isCompleted Boolean   @default(false)
  dueAt       DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  meeting   Meeting?  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  assignee  User?     @relation(fields: [assigneeId], references: [id], onDelete: SetNull)

  @@index([workspaceId, isCompleted, createdAt(sort: Desc)])
  @@index([meetingId])
  @@map("task")
}

model MeetingChunk {
  id        String                      @id @default(cuid())
  meetingId String
  content   String
  startMs   Int
  endMs     Int
  embedding Unsupported("vector(1536)")
  createdAt DateTime                    @default(now())
  updatedAt DateTime                    @updatedAt

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([meetingId])
  @@map("meeting_chunk")
}

model TranscriptSegment {
  id        String   @id @default(cuid())
  meetingId String
  speaker   String?
  startMs   Int
  endMs     Int
  text      String
  index     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@unique([meetingId, index])
  @@index([meetingId, startMs])
  @@map("transcript_segment")
}

enum ProcessingStage {
  TRANSCRIBE
  DIARIZE
  ANALYZE
  EMBED
}

enum ProcessingEventStatus {
  STARTED
  SUCCEEDED
  FAILED
}

model ProcessingEvent {
  id        String                @id @default(cuid())
  meetingId String
  stage     ProcessingStage
  status    ProcessingEventStatus
  message   String?
  metadata  Json?
  createdAt DateTime              @default(now())

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([meetingId, createdAt])
  @@map("processing_event")
}

// ─────────────────────────────────────────────
// Webhooks
// ─────────────────────────────────────────────

/**
 * Dead-letter store for incoming third-party webhooks (e.g. Recall.ai) that
 * could not be processed after retries. Operators replay these manually.
 */
model FailedWebhook {
  id            String   @id @default(cuid())
  /**
   * Source identifier, e.g. `recall`.
   */
  provider      String
  /**
   * Logical event name reported by the provider (`bot.done`, …).
   */
  eventType     String?
  /**
   * Raw payload exactly as received, retained for replay.
   */
  payload       Json
  /**
   * Last error message captured during processing.
   */
  error         String
  /**
   * Number of failed processing attempts so far.
   */
  attempts      Int      @default(1)
  /**
   * Provider-specific bot/job id for cross-referencing, when known.
   */
  externalBotId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([provider, createdAt])
  @@index([externalBotId])
  @@map("failed_webhook")
}
